# Copy to build/relay/.env (gitignored) and fill in before running
# docker compose -f build/relay/docker-compose.prod.yaml up -d

# Required: Meilisearch master key, shared between the relay and Meilisearch.
# Generate one with: openssl rand -base64 32
MEILI_MASTER_KEY=

# Optional: path to the relay config to mount into the container, relative
# to build/relay/ (compose resolves volume paths relative to the compose
# file). Defaults to ../../examples/relay/minimal.yaml. See
# examples/relay/ for ready-made presets (open, auth, ephemeral) — note
# these don't set a privkey, so add your own before deploying.
# RELAY_CONFIG=../../examples/relay/open.yaml
